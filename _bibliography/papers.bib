@inproceedings{Wang2021,
   abstract = {With the rapid development of big data,it has become a trend to use user portrait technology to transform user information into specific tags, to embody the image of users, and to provide users with personalized services. This article introduces the creation process of user portrait in detail, explains the analysis method of portrait accuracy, and summarizes and analyzes the typical application scenarios of user portrait technology.},
   author = {Xu Wang and Xiong Wei and Jiajun Ma and Guangjie Li and Jiancun Zuo},
