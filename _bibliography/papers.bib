   pages = {54–61},
   publisher = {Association for Computational Linguistics},
   title = {Wishful thinking: finding suggestions and `buy'wishes from product reviews},
   url = {http://portal.acm.org/citation.cfm?id=1860638},
   year = {2010},
}
